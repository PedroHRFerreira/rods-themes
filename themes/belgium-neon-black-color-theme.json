{
  "name": "Rods Themes: Belgium Neon Black",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#FFD60099",
    "foreground": "#F8FBFF",
    "descriptionForeground": "#A08B64",
    "errorForeground": "#FF2D55",
    "editor.background": "#000000",
    "editor.foreground": "#F8FBFF",
    "editorCursor.foreground": "#FFD600",
    "editor.selectionBackground": "#FFD60044",
    "editor.inactiveSelectionBackground": "#FFD60022",
    "editor.lineHighlightBackground": "#FFD60010",
    "editorLineNumber.foreground": "#A08B64",
    "editorLineNumber.activeForeground": "#FF1744",
    "editorGutter.background": "#000000",
    "editorGutter.addedBackground": "#00FF85",
    "editorGutter.modifiedBackground": "#FFD60A",
    "editorGutter.deletedBackground": "#FF2D55",
    "editorOverviewRuler.addedForeground": "#00FF85DD",
    "editorOverviewRuler.modifiedForeground": "#FFD60ADD",
    "editorOverviewRuler.deletedForeground": "#FF2D55DD",
    "minimapGutter.addedBackground": "#00FF85",
    "minimapGutter.modifiedBackground": "#FFD60A",
    "minimapGutter.deletedBackground": "#FF2D55",
    "diffEditor.insertedTextBackground": "#00FF8522",
    "diffEditor.removedTextBackground": "#FF2D5522",
    "editorIndentGuide.background1": "#222222",
    "editorIndentGuide.activeBackground1": "#FFD600",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#F8FBFF",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#FFD600",
    "activityBar.activeBorder": "#FF1744",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FF1744",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#F8FBFF",
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#050505",
    "tab.activeForeground": "#FF1744",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#A08B64",
    "panel.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#F8FBFF",
    "terminalCursor.foreground": "#FFD600",
    "button.background": "#FFD600",
    "button.foreground": "#000000",
    "button.hoverBackground": "#FFF176",
    "input.background": "#050505",
    "input.border": "#FFD60099",
    "dropdown.background": "#050505",
    "list.activeSelectionBackground": "#FFD60033",
    "list.highlightForeground": "#FF6D00",
    "gitDecoration.modifiedResourceForeground": "#FFD60A",
    "gitDecoration.addedResourceForeground": "#00FF85",
    "gitDecoration.deletedResourceForeground": "#FF2D55"
  },
  "tokenColors": [
    {"name":"Comment","scope":["comment","punctuation.definition.comment"],"settings":{"foreground":"#A08B64","fontStyle":"italic"}},
    {"name":"Keyword","scope":["keyword","storage.type","storage.modifier"],"settings":{"foreground":"#FFD600"}},
    {"name":"Function","scope":["entity.name.function","support.function"],"settings":{"foreground":"#FFF176"}},
    {"name":"Method","scope":["entity.name.function.member","meta.method"],"settings":{"foreground":"#FF6B8A"}},
    {"name":"Variable","scope":["variable","meta.definition.variable"],"settings":{"foreground":"#F8FBFF"}},
    {"name":"Parameter","scope":["variable.parameter","meta.parameter"],"settings":{"foreground":"#FF1744"}},
    {"name":"Type","scope":["entity.name.type","support.type","entity.name.class"],"settings":{"foreground":"#FF6D00"}},
    {"name":"Interface","scope":["entity.name.type.interface"],"settings":{"foreground":"#FF6D00","fontStyle":"italic"}},
    {"name":"String","scope":["string","constant.other.symbol"],"settings":{"foreground":"#FF1744"}},
    {"name":"Number","scope":["constant.numeric","constant.language.boolean"],"settings":{"foreground":"#FF6D00"}},
    {"name":"Property","scope":["variable.other.property","support.variable.property"],"settings":{"foreground":"#FF6B8A"}},
    {"name":"Operator","scope":["keyword.operator","punctuation.accessor"],"settings":{"foreground":"#FFD600"}},
    {"name":"Tag","scope":["entity.name.tag","entity.other.attribute-name"],"settings":{"foreground":"#FFD600"}},
    {"name":"Invalid","scope":["invalid","invalid.illegal"],"settings":{"foreground":"#FF2D55","fontStyle":"bold"}}
  ],
  "semanticTokenColors": {
    "variable": "#F8FBFF",
    "parameter": "#FF1744",
    "property": "#FF6B8A",
    "function": "#FFF176",
    "method": "#FF6B8A",
    "class": "#FF6D00",
    "interface": {"foreground":"#FF6D00","fontStyle":"italic"},
    "enum": "#FF6D00",
    "type": "#FF6D00",
    "keyword": "#FFD600",
    "string": "#FF1744",
    "number": "#FF6D00",
    "comment": {"foreground":"#A08B64","fontStyle":"italic"},
    "decorator": "#FFD600",
    "namespace": "#FFF176",
    "variable.readonly": "#FF6D00",
    "function.declaration": "#FFF176",
    "*.deprecated": {"foreground":"#A08B64","strikethrough":true}
  }
}
