    "minimapGutter.addedBackground": "#00FF85",
    "minimapGutter.modifiedBackground": "#FFD60A",
    "minimapGutter.deletedBackground": "#FF2D55",
    "diffEditor.insertedTextBackground": "#00FF8522",
    "diffEditor.removedTextBackground": "#FF2D5522",
    "editorIndentGuide.background1": "#222222",
    "editorIndentGuide.activeBackground1": "#FF1744",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#F8FBFF",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#FF1744",
    "activityBar.activeBorder": "#00E676",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#00E676",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#F8FBFF",
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#050505",
    "tab.activeForeground": "#00E676",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#9B706D",
    "panel.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#F8FBFF",
    "terminalCursor.foreground": "#FF1744",
    "button.background": "#FF1744",
    "button.foreground": "#000000",
    "button.hoverBackground": "#FF4F6D",
    "input.background": "#050505",
    "input.border": "#FF174499",
    "dropdown.background": "#050505",
    "list.activeSelectionBackground": "#FF174433",
    "list.highlightForeground": "#FFD600",
    "gitDecoration.modifiedResourceForeground": "#FFD60A",
    "gitDecoration.addedResourceForeground": "#00FF85",
    "gitDecoration.deletedResourceForeground": "#FF2D55"
  },
  "tokenColors": [
    {"name":"Comment","scope":["comment","punctuation.definition.comment"],"settings":{"foreground":"#9B706D","fontStyle":"italic"}},
    {"name":"Keyword","scope":["keyword","storage.type","storage.modifier"],"settings":{"foreground":"#FF1744"}},
    {"name":"Function","scope":["entity.name.function","support.function"],"settings":{"foreground":"#FF4F6D"}},
    {"name":"Method","scope":["entity.name.function.member","meta.method"],"settings":{"foreground":"#40FFB0"}},
    {"name":"Variable","scope":["variable","meta.definition.variable"],"settings":{"foreground":"#F8FBFF"}},
    {"name":"Parameter","scope":["variable.parameter","meta.parameter"],"settings":{"foreground":"#00E676"}},
    {"name":"Type","scope":["entity.name.type","support.type","entity.name.class"],"settings":{"foreground":"#FFD600"}},
    {"name":"Interface","scope":["entity.name.type.interface"],"settings":{"foreground":"#FFD600","fontStyle":"italic"}},
    {"name":"String","scope":["string","constant.other.symbol"],"settings":{"foreground":"#00E676"}},
    {"name":"Number","scope":["constant.numeric","constant.language.boolean"],"settings":{"foreground":"#FFD600"}},
    {"name":"Property","scope":["variable.other.property","support.variable.property"],"settings":{"foreground":"#40FFB0"}},
    {"name":"Operator","scope":["keyword.operator","punctuation.accessor"],"settings":{"foreground":"#FF1744"}},
    {"name":"Tag","scope":["entity.name.tag","entity.other.attribute-name"],"settings":{"foreground":"#FF1744"}},
    {"name":"Invalid","scope":["invalid","invalid.illegal"],"settings":{"foreground":"#FF2D55","fontStyle":"bold"}}
  ],
  "semanticTokenColors": {
    "variable": "#F8FBFF",
    "parameter": "#00E676",
    "property": "#40FFB0",
    "function": "#FF4F6D",
    "method": "#40FFB0",
    "class": "#FFD600",
    "interface": {"foreground":"#FFD600","fontStyle":"italic"},
    "enum": "#FFD600",
    "type": "#FFD600",
    "keyword": "#FF1744",
    "string": "#00E676",
    "number": "#FFD600",
    "comment": {"foreground":"#9B706D","fontStyle":"italic"},
    "decorator": "#FF1744",
    "namespace": "#FF4F6D",
    "variable.readonly": "#FFD600",
    "function.declaration": "#FF4F6D",
    "*.deprecated": {"foreground":"#9B706D","strikethrough":true}
  }
}
