{
  "name": "Rods Themes: Netherlands Neon Black",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#FF6D0099",
    "foreground": "#F8FBFF",
    "descriptionForeground": "#9A806D",
    "errorForeground": "#FF2D55",
    "editor.background": "#000000",
    "editor.foreground": "#F8FBFF",
    "editorCursor.foreground": "#FF6D00",
    "editor.selectionBackground": "#FF6D0044",
    "editor.inactiveSelectionBackground": "#FF6D0022",
    "editor.lineHighlightBackground": "#FF6D0010",
    "editorLineNumber.foreground": "#9A806D",
    "editorLineNumber.activeForeground": "#FFFFFF",
    "editorGutter.background": "#000000",
    "editorGutter.addedBackground": "#00FF85",
    "editorGutter.modifiedBackground": "#FFD60A",
    "editorGutter.deletedBackground": "#FF2D55",
    "editorOverviewRuler.addedForeground": "#00FF85DD",
    "editorOverviewRuler.modifiedForeground": "#FFD60ADD",
    "editorOverviewRuler.deletedForeground": "#FF2D55DD",
    "minimapGutter.addedBackground": "#00FF85",
    "minimapGutter.modifiedBackground": "#FFD60A",
    "minimapGutter.deletedBackground": "#FF2D55",
    "diffEditor.insertedTextBackground": "#00FF8522",
    "diffEditor.removedTextBackground": "#FF2D5522",
    "editorIndentGuide.background1": "#222222",
    "editorIndentGuide.activeBackground1": "#FF6D00",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#F8FBFF",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#FF6D00",
    "activityBar.activeBorder": "#FFFFFF",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#F8FBFF",
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#050505",
    "tab.activeForeground": "#FFFFFF",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#9A806D",
    "panel.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#F8FBFF",
    "terminalCursor.foreground": "#FF6D00",
    "button.background": "#FF6D00",
    "button.foreground": "#000000",
    "button.hoverBackground": "#FF9E40",
    "input.background": "#050505",
    "input.border": "#FF6D0099",
    "dropdown.background": "#050505",
    "list.activeSelectionBackground": "#FF6D0033",
    "list.highlightForeground": "#2979FF",
    "gitDecoration.modifiedResourceForeground": "#FFD60A",
    "gitDecoration.addedResourceForeground": "#00FF85",
    "gitDecoration.deletedResourceForeground": "#FF2D55"
  },
  "tokenColors": [
    {"name":"Comment","scope":["comment","punctuation.definition.comment"],"settings":{"foreground":"#9A806D","fontStyle":"italic"}},
    {"name":"Keyword","scope":["keyword","storage.type","storage.modifier"],"settings":{"foreground":"#FF6D00"}},
    {"name":"Function","scope":["entity.name.function","support.function"],"settings":{"foreground":"#FF9E40"}},
    {"name":"Method","scope":["entity.name.function.member","meta.method"],"settings":{"foreground":"#7DA8FF"}},
    {"name":"Variable","scope":["variable","meta.definition.variable"],"settings":{"foreground":"#F8FBFF"}},
    {"name":"Parameter","scope":["variable.parameter","meta.parameter"],"settings":{"foreground":"#FFFFFF"}},
    {"name":"Type","scope":["entity.name.type","support.type","entity.name.class"],"settings":{"foreground":"#2979FF"}},
    {"name":"Interface","scope":["entity.name.type.interface"],"settings":{"foreground":"#2979FF","fontStyle":"italic"}},
    {"name":"String","scope":["string","constant.other.symbol"],"settings":{"foreground":"#FFFFFF"}},
    {"name":"Number","scope":["constant.numeric","constant.language.boolean"],"settings":{"foreground":"#2979FF"}},
    {"name":"Property","scope":["variable.other.property","support.variable.property"],"settings":{"foreground":"#7DA8FF"}},
    {"name":"Operator","scope":["keyword.operator","punctuation.accessor"],"settings":{"foreground":"#FF6D00"}},
    {"name":"Tag","scope":["entity.name.tag","entity.other.attribute-name"],"settings":{"foreground":"#FF6D00"}},
    {"name":"Invalid","scope":["invalid","invalid.illegal"],"settings":{"foreground":"#FF2D55","fontStyle":"bold"}}
  ],
  "semanticTokenColors": {
    "variable": "#F8FBFF",
    "parameter": "#FFFFFF",
    "property": "#7DA8FF",
    "function": "#FF9E40",
    "method": "#7DA8FF",
    "class": "#2979FF",
    "interface": {"foreground":"#2979FF","fontStyle":"italic"},
    "enum": "#2979FF",
    "type": "#2979FF",
    "keyword": "#FF6D00",
    "string": "#FFFFFF",
    "number": "#2979FF",
    "comment": {"foreground":"#9A806D","fontStyle":"italic"},
    "decorator": "#FF6D00",
    "namespace": "#FF9E40",
    "variable.readonly": "#2979FF",
    "function.declaration": "#FF9E40",
    "*.deprecated": {"foreground":"#9A806D","strikethrough":true}
  }
}
